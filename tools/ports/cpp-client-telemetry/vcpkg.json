{
  "name": "cpp-client-telemetry",
  "version": "3.10.161.1",
  "description": "Microsoft 1DS C/C++ Client Telemetry Library",
  "homepage": "https://github.com/microsoft/cpp_client_telemetry",
  "license": "Apache-2.0",
  "supports": "((windows & !mingw) | linux | osx | ios | android) & !uwp",
  "dependencies": [
    {
      "name": "curl",
      "default-features": false,
      "features": [
        "openssl"
      ],
      "platform": "linux | android"
    },
    "nlohmann-json",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib"
  ],
  "default-features": [
    "system-sqlite"
  ],
  "features": {
    "system-sqlite": {
      "description": "Link the external vcpkg sqlite3 package for the offline storage cache (default).",
      "dependencies": [
        {
          "name": "sqlite3",
          "default-features": false
        }
      ]
    },
    "minimal-sqlite": {
      "description": "Build a private, feature-stripped SQLite compiled from the SDK's vendored amalgamation instead of linking the external sqlite3 package. Smaller footprint; combine with [core,minimal-sqlite] to also drop the sqlite3 dependency."
    }
  }
}
